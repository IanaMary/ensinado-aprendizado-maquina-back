# Variáveis do backend no docker-compose. Copie para .env.docker e ajuste.
# NÃO comite .env.docker (já está no .dockerignore/.gitignore).

# Banco (serviço "mongo" do compose)
MONGO_URL=mongodb://mongo:27017
MONGO_DB=iana

# Auth — gere um valor próprio: python -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=troque-por-um-segredo-forte-de-pelo-menos-32-bytes

# CORS: o frontend é servido em http://localhost:8080 (mesmo origin via proxy /api,
# então CORS normalmente nem é acionado; deixado aqui por garantia).
ALLOWED_ORIGINS=http://localhost:8080

# Chatbot tutor (NVIDIA) — opcional; sem a chave o chat responde 503, o resto funciona.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# E-mail de convite (Gmail via SMTP) — opcional; vazio = convite não envia e-mail
# (a API devolve o link do convite na resposta). App Password de 16 dígitos.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
FRONTEND_URL=http://localhost:8080
